{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Salesforce Org Compare",
  "version": "2.2.1",
  "description": "Compare Salesforce orgs using your browser session.",
  "homepage_url": "https://salesforceorgcompare.web.app/",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png",
    "512": "icons/icon-512.png"
  },
  "action": {
    "default_title": "Salesforce Org Compare",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "cookies",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
  "https://*.salesforce.com/*",
  "https://*.my.salesforce.com/*",
  "https://*.force.com/*",
  "https://*.lightning.force.com/*",
  "https://*.visual.force.com/*",
  "https://*.vf.force.com/*",
  "https://*.visualforce.com/*",
  "https://*.cloudforce.com/*",
  "https://*.salesforce-setup.com/*",
  "https://salesforceorgcompare.web.app/*",
  "https://script.google.com/*",
  "https://script.googleusercontent.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; worker-src 'self'; style-src 'self' 'unsafe-inline';"
  }
}


